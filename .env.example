# =============================================================================
# OpenMemoryLab — Environment Variables
#
# Copy this file to .env and fill in the values you need.
# .env is automatically read by Docker Compose and by `oml` (via python-dotenv).
#
#   cp .env.example .env
# =============================================================================

# ── LLM providers ─────────────────────────────────────────────────────────────
# Only set the keys for providers you actually use.
# The CLI always defaults to the mock LLM (no key required) for safe testing.

# OpenAI — required for: oml ... --model openai:gpt-4o-mini
OPENAI_API_KEY=

# Google Gemini — required for: oml ... --model gemini:gemini-1.5-flash
GEMINI_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# Local Ollama endpoint. Default points to the host machine when running in Docker.
# Change to http://ollama:11434 if using the Ollama service in docker-compose.
OLLAMA_HOST=http://host.docker.internal:11434

# ── Default model ─────────────────────────────────────────────────────────────
# Override the default model set in oml.yaml.
# Examples: mock | ollama:qwen3:4b | openai:gpt-4o-mini | gemini:gemini-1.5-flash
OML_MODEL=mock
